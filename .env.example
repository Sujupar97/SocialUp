# Supabase
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# TikTok OAuth (client key only — secret goes in Edge Function Secrets)
VITE_TIKTOK_CLIENT_KEY=YOUR_TIKTOK_CLIENT_KEY

# Gemini AI
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# N8N Webhook URLs (your production N8N instance)
VITE_N8N_WEBHOOK_BASE=https://your-n8n-instance.com/webhook
VITE_N8N_GENERATE_DESCRIPTIONS=
VITE_N8N_UPDATE_STATUS=
VITE_N8N_SAVE_COMMENT=
VITE_N8N_PROCESS_VIDEO=
VITE_N8N_PUBLISH_TIKTOK=

# Automation Server (Express backend)
VITE_AUTOMATION_SERVER=https://your-automation-server.com
VITE_BROWSER_SERVER_WS=wss://your-browser-server.com

# Scripts-side environment (for automation server)
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
TIKTOK_CLIENT_KEY=YOUR_TIKTOK_CLIENT_KEY
TIKTOK_CLIENT_SECRET=YOUR_TIKTOK_CLIENT_SECRET
AUTOMATION_SERVER_PORT=3001
N8N_WEBHOOK_BASE=https://your-n8n-instance.com/webhook
